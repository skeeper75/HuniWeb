{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/product/**",
              "ui_kits/huni_printing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Sans|Noto Sans KR))/i]",
        "message": "Font not provided by the design system. Available: Noto Sans, Noto Sans KR."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|pin|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, pin, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:best|new|up|design|brand|dark|neutral)$/]",
        "message": "<Badge> tone must be one of 'best' | 'new' | 'up' | 'design' | 'brand' | 'dark' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='pin'] > Literal[value!=/^(?:down|up)$/]",
        "message": "<Badge> pin must be one of 'down' | 'up'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|leadingIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, leadingIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|neutral|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'neutral' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|glyph|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: tone, glyph."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|warn|muted)$/]",
        "message": "<Callout> tone must be one of 'brand' | 'warn' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|label|selected|onClick|size|swatchStyle|key|ref|className|style|children)$/]",
        "message": "<ColorChip> doesn't accept that prop. Declared props: color, label, selected, onClick, size, swatchStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='FinishSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|open|onToggle|openLabel|closeLabel|key|ref|className|style|children)$/]",
        "message": "<FinishSection> doesn't accept that prop. Declared props: title, open, onToggle, openLabel, closeLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|showMark|size|withCom|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, showMark, size, withCom."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:color|dark|reversed)$/]",
        "message": "<Logo> variant must be one of 'color' | 'dark' | 'reversed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionButtonGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|columns|key|ref|className|style|children)$/]",
        "message": "<OptionButtonGroup> doesn't accept that prop. Declared props: options, value, onChange, columns."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|info|onInfo|right|key|ref|className|style|children)$/]",
        "message": "<OptionField> doesn't accept that prop. Declared props: label, info, onInfo, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pagination'] > JSXAttribute > JSXIdentifier[name!=/^(?:page|count|onChange|key|ref|className|style|children)$/]",
        "message": "<Pagination> doesn't accept that prop. Declared props: page, count, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|amount|key|ref|className|style|children)$/]",
        "message": "<PriceLine> doesn't accept that prop. Declared props: label, amount."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuantityStepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|onChange|size|style|key|ref|className|style|children)$/]",
        "message": "<QuantityStepper> doesn't accept that prop. Declared props: value, min, max, step, onChange, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuantityStepper'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<QuantityStepper> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|name|value|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: checked, onChange, label, name, value, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|placeholder|onChange|badge|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<SelectBox> doesn't accept that prop. Declared props: options, value, placeholder, onChange, badge, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectBox'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<SelectBox> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:stops|index|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: stops, index, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|onChange|suffix|helper|error|disabled|align|size|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: value, placeholder, onChange, suffix, helper, error, disabled, align, size, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TextField> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<TextField> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
